{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Detect Task Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "objective", "assumptions", "research_needed", "tasks", "acceptance"],
  "properties": {
    "project": { "type": "string", "const": "__PROJECT_NAME__" },
    "objective": { "type": "string" },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "research_needed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "why_it_matters", "expected_output"],
        "properties": {
          "question": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "expected_output": { "type": "string" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "title", "instructions", "target_paths", "depends_on", "verification"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["research", "design", "implementation", "test", "experiment", "documentation", "review_fix"]
          },
          "title": { "type": "string" },
          "instructions": { "type": "string" },
          "target_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verification": { "type": "string" }
        }
      }
    },
    "acceptance": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}


