{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Detect Git Directive",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "intent", "actions"],
  "properties": {
    "project": { "type": "string", "const": "__PROJECT_NAME__" },
    "intent": { "type": "string", "description": "why these git actions, in one line" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "rationale"],
        "properties": {
          "op": {
            "type": "string",
            "enum": ["status", "branch", "checkout", "commit", "merge", "tag", "push"]
          },
          "branch": { "type": "string", "description": "branch name for branch/checkout/merge" },
          "target": { "type": "string", "description": "merge source ref, or ref to tag" },
          "message": { "type": "string", "description": "commit or tag message" },
          "version": { "type": "string", "description": "SemVer tag like v1.0.0 (tag op)" },
          "trailers": {
            "type": "array",
            "items": { "type": "string", "examples": ["Aligned-By: r-2026...", "Override: initial scaffold"] },
            "description": "commit trailers; required when committing protected paths"
          },
          "requires_human_confirmation": {
            "type": "boolean",
            "description": "must be true for push; Codex must stop and ask the human"
          },
          "rationale": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

